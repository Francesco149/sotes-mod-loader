# oss_loader.cfg — SotES Mod Loader config.  Copy beside the game exe (next to version.dll)
# and rename to `oss_loader.cfg`.  key=value, one per line; # or ; comments.  The launcher
# (later) writes this; it's hand-editable too.  Missing file / keys = the defaults below.

# Auto-dismiss the game's pre-launch launcher dialog (SotES #32770) so the game boots
# hands-free.  ON by default (built-in) — the loader clicks "Launch" for you in the mode below.
# 1 = dismiss (default), 0 = leave the launcher up so you pick the mode yourself.
skip_launcher=1

# When skip_launcher dismisses the launcher, which display mode to select.  Default 1
# (windowed) — the sane default for a hands-free/dev launch.  0 = fullscreen.  (Only
# applies when skip_launcher=1; otherwise the user picks in the launcher.)
windowed=1

# The ImGui UI host: your mod.ui panels, fed by a lock-free snapshot the game's engine thread builds
# each frame (so it never stalls the game).  In borderless takeover (ddraw_takeover=1) it draws as an
# IN-GAME OVERLAY on top of the game frame; otherwise as a separate companion window.  On by default
# once the executor arms.  1 = enable (default), 0 = disable entirely.
ui=1

# The overlay/companion show/hide toggle, as a Windows virtual-key code (0 = default F10).  F10 is the
# default because F8 collides with SotES' in-game menu key.  Common codes: F1..F12 = 112..123,
# INSERT = 45, HOME = 36, END = 35.  (The overlay is mouse-only — the keyboard stays with the game.)
ui_key=0

# Engine-side snapshot refresh rate in Hz (0 = default 30).  Higher = snappier live data but more
# per-frame work on the game thread; the UI itself only redraws when the snapshot changes.
ui_hz=0

# The DirectDraw present backend: hook the game's per-frame present, capture the finished frame, and
# re-present it through our own vsync'd D3D11 swapchain.  Powers the companion-window game mirror and
# the borderless-fullscreen takeover below.  1 = on (default), 0 = off.
ddraw=1

# Borderless-fullscreen TAKEOVER: instead of only mirroring, OWN the game window — skip the game's own
# (unsynced, ~130fps, tearing) present and drive the window ourselves: borderless-fullscreen, vsync'd,
# sharp-bilinear upscale, aspect-correct pillarbox.  This is what makes windowed play look/feel like a
# smooth exclusive-fullscreen.  The mod.ui host also draws as an in-game overlay on top of the frame
# here (ui_key toggles it), replacing the companion window.  0 = off (default — the game window as the
# game drew it), 1 = on.  (Requires ddraw=1.)
ddraw_takeover=0

# Dev profiler: time the loader's per-frame overhead on the engine thread (the safepoint drain, the
# UI snapshot build, and the roster heap-scan) and log avg/max microseconds every 5s to
# oss_modloader.log.  0 = off (default, zero cost), 1 = on.
profile=0

# Keep the game running while its window is UNFOCUSED (it otherwise idles its input poll, so the
# loader's safepoint stops firing when the window loses foreground).  ON by default (built-in): the
# companion UI window steals foreground when you click it, which would otherwise freeze the game +
# the overlay.  Re-posts WM_ACTIVATEAPP only (no focus steal).  1 = on (default), 0 = off.
keepactive=1

# Auto-load a save at boot (SotES only): drive the title + save-picker menus straight into a save, so
# launch takes you into your game instead of the title screen.  Handy as a QoL shortcut (and for
# testing/profiling, which needs to reach actual gameplay).  0 = off (default), 1 = on.
# autoload_slot selects the savedataNN file index; -1 (default) loads the picker's newest/default save.
autoload=0
autoload_slot=-1
