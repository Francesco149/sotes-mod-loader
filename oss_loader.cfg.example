# oss_loader.cfg — SotES Mod Loader config.  Copy beside the game exe (next to version.dll)
# and rename to `oss_loader.cfg`.  key=value, one per line; # or ; comments.  The launcher
# (later) writes this; it's hand-editable too.  Missing file / keys = the defaults below.

# Auto-dismiss the game's pre-launch launcher dialog (SotES #32770) so the game boots
# hands-free.  OFF by default — end users click "Launch" themselves; a launcher/dev turns
# it on.  1 = dismiss, 0 = leave it (default).
skip_launcher=0

# When skip_launcher dismisses the launcher, which display mode to select.  Default 1
# (windowed) — the sane default for a hands-free/dev launch.  0 = fullscreen.  (Only
# applies when skip_launcher=1; otherwise the user picks in the launcher.)
windowed=1

# The ImGui UI host (P5): a loader window + an in-game overlay mirror.  On by default once the
# executor arms.  1 = enable (default), 0 = disable entirely.
ui=1

# Toggle keys as Windows virtual-key codes (0 = the defaults: F8 for the loader window, INSERT
# for the overlay).  Common codes: F1..F12 = 112..123, INSERT = 45, HOME = 36, END = 35.
ui_key=0
overlay_key=0
