# oss_loader.cfg — SotES Mod Loader config.  Copy beside the game exe (next to version.dll)
# and rename to `oss_loader.cfg`.  key=value, one per line; # or ; comments.  The launcher
# (later) writes this; it's hand-editable too.  Missing file / keys = the defaults below.

# Auto-dismiss the game's pre-launch launcher dialog (SotES #32770) so the game boots
# hands-free.  OFF by default — end users click "Launch" themselves; a launcher/dev turns
# it on.  1 = dismiss, 0 = leave it (default).
skip_launcher=0

# When skip_launcher dismisses the launcher, which display mode to select.  Default 1
# (windowed) — the sane default for a hands-free/dev launch.  0 = fullscreen.  (Only
# applies when skip_launcher=1; otherwise the user picks in the launcher.)
windowed=1

# The ImGui UI host (P5): a loader-owned companion window fed by a lock-free snapshot the game's
# engine thread builds each frame (so it never stalls the game).  On by default once the executor
# arms.  1 = enable (default), 0 = disable entirely.
ui=1

# The window show/hide toggle, as a Windows virtual-key code (0 = default F8).  Common codes:
# F1..F12 = 112..123, INSERT = 45, HOME = 36, END = 35.
ui_key=0

# Engine-side snapshot refresh rate in Hz (0 = default 30).  Higher = snappier live data but more
# per-frame work on the game thread; the UI itself only redraws when the snapshot changes.
ui_hz=0

# Dev profiler: time the loader's per-frame overhead on the engine thread (the safepoint drain, the
# UI snapshot build, and the roster heap-scan) and log avg/max microseconds every 5s to
# oss_modloader.log.  0 = off (default, zero cost), 1 = on.
profile=0

# Keep the game running while its window is UNFOCUSED (it otherwise idles its input poll, so the
# loader's safepoint stops firing when you alt-tab away).  Needed for headless testing.  Re-posts
# WM_ACTIVATEAPP to the game window.  0 = off (default), 1 = on.  (Auto-enabled when autoload=1.)
keepactive=0

# Dev auto-load (SotES only): drive the title + save-picker menus at boot to load a save, so
# testing/profiling reaches actual gameplay instead of the title.  0 = off (default), 1 = on.
# autoload_slot selects the savedataNN file index; -1 (default) loads the picker's newest/default save.
autoload=0
autoload_slot=-1
